---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const blogEntries: CollectionEntry<"blog">[] = await getCollection("blog");
const newsEntries: CollectionEntry<"news">[] = await getCollection("news");

const parseDmyDate = (dmy: string) => {
    const [day, month, year] = dmy.split("/");
    return new Date(Number(year), Number(month) - 1, Number(day));
};

const formatDateForDisplay = (dmy: string) =>
    new Intl.DateTimeFormat("en-GB", {
        year: "numeric",
        month: "short",
        day: "2-digit",
    }).format(parseDmyDate(dmy));

const getYouTubeVideoId = (url?: string) => {
    if (!url) return "";
    const match = url.match(
        /(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/,
    );
    return match ? match[1] : "";
};

const sortedBlogEntries = blogEntries.sort((a, b) => {
    return (
        parseDmyDate(b.data.date).getTime() -
        parseDmyDate(a.data.date).getTime()
    );
});

const sortedNewsEntries = newsEntries.sort((a, b) => {
    return (
        parseDmyDate(b.data.date).getTime() -
        parseDmyDate(a.data.date).getTime()
    );
});

const allTags = Array.from(
    new Set(sortedBlogEntries.flatMap((entry) => entry.data.tags || [])),
).sort((a, b) => a.localeCompare(b));

const navItems = [
    { label: "Download", href: "https://cangjie-lang.cn/en/download" },
    { label: "Docs", href: "https://cangjie-lang.cn/en/docs" },
    { label: "Code Repo", href: "https://gitcode.com/Cangjie" },
    { label: "About Team", href: "/about" },
];
---

<Layout title="Cangjie UK Team">
    <header class="site-header">
        <div class="site-header-inner">
            <a href="/" class="brand brand-link">
                Cangjie UK
                <span class="brand-mark">
                    <img
                        class="brand-logo"
                        src="/assets/cangjie-logo.png"
                        alt="Cangjie Logo"
                        loading="lazy"
                    />
                </span>
            </a>
            <nav class="site-nav" aria-label="Primary">
                {
                    navItems.map((item) => (
                        <a href={item.href} class="nav-link">
                            {item.label}
                        </a>
                    ))
                }
            </nav>
        </div>
    </header>
    <div class="container">
        <header class="hero-section">
            <h1 class="main-title">Cangjie UK Team</h1>
            <p class="subtitle" aria-label="Site tagline">
                Building and empowering the Cangjie ecosystem in the UK
            </p>
        </header>

        <main class="content">
            <section class="feature-rail" aria-label="Key Cangjie features">
                <a
                    class="feature-chip feature-chip-primary"
                    href="learn/learn.html"
                >
                    <span class="feature-code">CJ</span>
                    <span class="feature-text">
                        <span class="feature-label">Learn Cangjie</span>
                        <span class="feature-subtitle">Start tutorial</span>
                    </span>
                </a>
                <a class="feature-chip" href="/effectHandlersIntro">
                    <span class="feature-code">EH</span>
                    <span class="feature-label">Effect Handler</span>
                </a>
                <a class="feature-chip" href="/distributed-actors">
                    <span class="feature-code">ACT</span>
                    <span class="feature-label">Actor</span>
                </a>
            </section>

            <div class="main-layout">
                <section class="projects-section" id="projects">
                    <div class="section-header">
                        <h2>Blog Posts</h2>
                    </div>
                    <div class="projects-grid">
                        {
                            sortedBlogEntries.map((entry) => {
                                const videoId = getYouTubeVideoId(
                                    entry.data.descriptionVideo,
                                );

                                return (
                                    <a
                                        class="project-card"
                                        href={`/blog/${entry.slug}/`}
                                    >
                                        <h3>{entry.data.title}</h3>
                                        <p class="project-date">
                                            {formatDateForDisplay(
                                                entry.data.date,
                                            )}
                                        </p>

                                        {(entry.data.description ||
                                            entry.data.descriptionImage) && (
                                            <div
                                                class={`project-summary ${
                                                    entry.data.descriptionImage
                                                        ? "project-summary-with-image"
                                                        : ""
                                                }`}
                                            >
                                                {entry.data.description && (
                                                    <p class="project-summary-text">
                                                        {entry.data.description}
                                                    </p>
                                                )}
                                                {entry.data
                                                    .descriptionImage && (
                                                    <div class="project-summary-thumb">
                                                        <img
                                                            src={
                                                                entry.data
                                                                    .descriptionImage
                                                            }
                                                            alt={
                                                                entry.data
                                                                    .description ||
                                                                entry.data.title
                                                            }
                                                            loading="lazy"
                                                        />
                                                    </div>
                                                )}
                                            </div>
                                        )}

                                        {videoId && (
                                            <div class="project-video-preview">
                                                <div class="project-video-thumb">
                                                    <img
                                                        src={`https://img.youtube.com/vi/${videoId}/hqdefault.jpg`}
                                                        alt=""
                                                        loading="lazy"
                                                    />
                                                    <span
                                                        class="project-video-play"
                                                        aria-hidden="true"
                                                    />
                                                </div>
                                                <div class="project-video-meta">
                                                    <span class="project-video-source">
                                                        youtube.com
                                                    </span>
                                                    <strong class="project-video-title">
                                                        {entry.data.title}
                                                    </strong>
                                                    <span class="project-video-desc">
                                                        {entry.data
                                                            .description || ""}
                                                    </span>
                                                </div>
                                            </div>
                                        )}

                                        {entry.data.tags &&
                                            entry.data.tags.length > 0 && (
                                                <div class="project-tags">
                                                    {entry.data.tags.map(
                                                        (tag) => (
                                                            <span class="tag">
                                                                {tag}
                                                            </span>
                                                        ),
                                                    )}
                                                </div>
                                            )}
                                    </a>
                                );
                            })
                        }
                    </div>
                </section>

                <aside class="sidebar-column" aria-label="Sidebar">
                    <section class="sidebar-card news-card">
                        <h3>News</h3>
                        <div class="news-list" aria-label="News">
                            {
                                sortedNewsEntries
                                    .slice(0, 4)
                                    .map((entry, index) => (
                                        <a
                                            href={`/news/${index}`}
                                            class="news-item"
                                        >
                                            <span class="news-item-title">
                                                {entry.data.title}
                                            </span>
                                            <span class="news-item-date">
                                                {formatDateForDisplay(
                                                    entry.data.date,
                                                )}
                                            </span>
                                        </a>
                                    ))
                            }
                        </div>
                    </section>

                    <section class="sidebar-card community-card">
                        <h3>Community</h3>
                        <p>
                            Join our official Discord to ask questions, share
                            ideas, and discuss with other Cangjie developers.
                        </p>
                        <a
                            class="community-cta"
                            href=""
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Join Cangjie UK Discord server"
                        >
                            <img
                                class="community-cta-icon"
                                src="/assets/discord.png"
                                alt=""
                                loading="lazy"
                            />
                        </a>
                    </section>

                    <section class="sidebar-card tag-card">
                        <h3>Tag</h3>
                        <div class="tag-chips" aria-label="Blog tags">
                            {
                                allTags.map((tag) => (
                                    <span class="tag">{tag}</span>
                                ))
                            }
                        </div>
                    </section>

                    <a
                        class="sidebar-card tech-talk-card"
                        href="https://www.youtube.com/watch?v=_pKV0zqoeZQ&feature=youtu.be"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <div class="tech-talk-thumb">
                            <img
                                src="https://img.youtube.com/vi/_pKV0zqoeZQ/hqdefault.jpg"
                                alt="YouTube cover for featured tech talk"
                                loading="lazy"
                            />
                            <div class="tech-talk-badge">Tech Talk</div>
                        </div>
                        <div class="tech-talk-meta">
                            <h3>Featured tech talk</h3>
                            <p class="tech-talk-title">
                                Expressive structured control with effect
                                handlers by Prof. Dan R. Ghica
                            </p>
                        </div>
                    </a>

                    <section class="sidebar-card partners-card">
                        <h3>Partners</h3>
                        <ul class="partners-list">
                            <li>
                                <a
                                    href="https://www.eclipse.org/"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    >Eclipse Foundation</a
                                >
                            </li>
                            <li>
                                <a
                                    href="https://www.openharmony.cn/homepage/"
                                    target="_blank"
                                    rel="noopener noreferrer">OpenHarmony</a
                                >
                            </li>
                        </ul>
                    </section>

                    <section class="sidebar-card follow-us-card" id="about">
                        <h3>Follow us</h3>
                        <nav class="social-links" aria-label="Official links">
                            <a
                                class="social-link"
                                href="https://www.youtube.com/@Cangjie_Lang"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <img
                                    class="social-icon-img"
                                    src="/assets/youtube.png"
                                    alt=""
                                />
                                <span class="social-label">YouTube</span>
                            </a>
                            <a
                                class="social-link"
                                href="https://x.com/Cangjie_Lang"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <img
                                    class="social-icon-img"
                                    src="/assets/twitter.png"
                                    alt=""
                                />
                                <span class="social-label">X (Twitter)</span>
                            </a>
                            <a
                                class="social-link"
                                href="https://www.linkedin.com/company/cangjie/"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <img
                                    class="social-icon-img"
                                    src="/assets/linkedin.png"
                                    alt=""
                                />
                                <span class="social-label">LinkedIn</span>
                            </a>
                            <a
                                class="social-link"
                                href="https://gitcode.com/Cangjie/cangjie_docs"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <img
                                    class="social-icon-img"
                                    src="/assets/gitcode.png"
                                    alt=""
                                />
                                <span class="social-label">GitCode</span>
                            </a>
                        </nav>
                    </section>
                </aside>
            </div>
        </main>
    </div>
</Layout>
